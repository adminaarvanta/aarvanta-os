# Copy to /opt/aarvanta/voice-relay/.env on EC2

PORT=8090

# Same OpenAI key used by Aarvanta OS is fine
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Twilio auth token (for WebSocket signature validation)
TWILIO_AUTH_TOKEN=

# MUST exactly match the url= in TwiML ConversationRelay (and Vercel env)
# Path-based on onboarding host:
# VOICE_RELAY_WSS_URL=wss://onboarding.aarvanta.co/voice-relay/ws
# Or dedicated subdomain:
# VOICE_RELAY_WSS_URL=wss://voice.aarvanta.co/ws
VOICE_RELAY_WSS_URL=

# Optional: push transcripts into Voice OS after each call
# AARVANTA_VOICE_CALLBACK_URL=https://os.aarvanta.co/api/webhooks/voice-relay
# VOICE_RELAY_CALLBACK_SECRET=

# VOICE_RELAY_VERIFY_SIGNATURES=true
# VOICE_RELAY_MAX_TOKENS=70
# VOICE_AGENT_SYSTEM_PROMPT=You are Aarvanta's phone receptionist...
