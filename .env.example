# Copy to .env.local for local development or set in Vercel → Settings → Environment Variables.

# --- Core ---
# demo = in-memory data, no login. production = Firestore + session auth.
APP_MODE=production

# Public URL (required for Twilio webhook signatures and outbound links)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- Auth (required in production) ---
AUTH_SECRET=generate-a-long-random-secret
AUTH_EMAIL=agent@yourcompany.com
AUTH_PASSWORD=your-secure-password
AUTH_USER_ID=user_prod

# --- Tenant scope (required in production) ---
TENANT_ID=tenant_prod
WORKSPACE_ID=ws_prod
COMPANY_ID=company_prod
ORGANIZATION_NAME=Aarvanta OS
WORKSPACE_NAME=Main workspace

# --- Firebase / Firestore (required in production) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Force datastore backend: memory | firestore (optional; auto-detected)
# DATASTORE=firestore

# --- Cron (recommended in production) ---
# Protects /api/cron/sync-email. Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- OpenAI (optional — AI summaries, CRM scoring, workforce) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
AI_AUTO_SUMMARIZE=true
# AI_ALLOW_HEURISTIC_FALLBACK=false
# AI_CRM_QUALIFICATION_THRESHOLD=50

# --- WhatsApp Cloud API (optional) ---
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Twilio SMS & Voice (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Gmail IMAP/SMTP (optional) ---
GMAIL_USER=support@yourdomain.com
GMAIL_APP_PASSWORD=
EMAIL_FROM=support@yourdomain.com
# EMAIL_REPLY_TO=
# EMAIL_MESSAGE_ID_DOMAIN=

# --- Channels ---
# CHANNELS_SIMULATE=true

# --- Cookies ---
# COOKIE_SECURE=true

# --- Demo / presentation ---
# ENABLE_LIVE_DEMO=true

# --- SSO (optional) ---
# SSO_AUTO_PROVISION=true
